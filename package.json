{
  "name": "lighthouse-reporter",
  "version": "0.3.0",
  "description": "Audita todas las páginas de tu sitio web con Lighthouse y genera un reporte HTML estático — sin pantallas en blanco, sin servidor.",
  "type": "module",
  "keywords": [
    "lighthouse",
    "seo",
    "performance",
    "audit",
    "web vitals",
    "accessibility",
    "sitemap",
    "broken-links",
    "meta-tags",
    "cli"
  ],
  "author": "CamiloCuspian",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CamiloCuspian/lighthouse-site-audit-tool.git"
  },
  "homepage": "https://github.com/CamiloCuspian/lighthouse-site-audit-tool#readme",
  "bugs": {
    "url": "https://github.com/CamiloCuspian/lighthouse-site-audit-tool/issues"
  },
  "scripts": {
    "audit": "node cli/index.js",
    "lint": "eslint cli/",
    "format": "prettier --write cli/"
  },
  "bin": {
    "lighthouse-reporter": "cli/index.js"
  },
  "files": [
    "cli/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chrome-launcher": "^1.1.2",
    "commander": "^12.0.0",
    "lighthouse": "^12.0.0",
    "node-fetch": "^3.3.2",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2"
  }
}
